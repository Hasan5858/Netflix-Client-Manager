---
import Layout from '../../layouts/Layout.astro';
import ClientDashboard from '../../components/ClientDashboard';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const db = Astro.locals.runtime.env.DB;
const { results } = await db.prepare(
  `SELECT * FROM clients WHERE id = ?`
).bind(id).all();

const client = results[0] as any;

if (!client) {
  return new Response('Client not found', { status: 404 });
}
---

<Layout title={`Dashboard - ${client.name}`}>
  <div class="min-h-screen flex flex-col items-center justify-center p-6 bg-radial from-[#222] to-black">
    <div class="max-w-4xl w-full">
      <div class="mb-6 text-center border-b border-gray-800 pb-6">
        <h1 class="text-4xl font-bold text-white mb-2">Client Dashboard</h1>
        <p class="text-gray-400">Welcome, <span class="font-bold text-gray-200">{client.name}</span></p>
        <p class="text-xs text-gray-600 mt-2 font-mono">ID: {client.id}</p>
      </div>

      <div data-client-id={id} data-client-name={client.name}>
        <ClientDashboard client:load clientId={id} clientName={client.name} />
      </div>
    </div>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { Lock, ArrowRight } from 'lucide-react';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const email = data.get('email')?.toString().trim();
    const password = data.get('password')?.toString().trim();

    const ADMIN_EMAIL = 'admin@example.com';
    const ADMIN_PASS = 'admin123';

    if (email === ADMIN_EMAIL && password === ADMIN_PASS) {
      // Set cookie and redirect
      Astro.cookies.set('admin_access_token', 'true', {
        path: '/',
        httpOnly: true,
        secure: import.meta.env.PROD, // Only secure in production
        maxAge: 60 * 60 * 24 // 1 day
      });
      return Astro.redirect('/master-admin-panel');
    } else {
        return Astro.redirect('/admin-login?error=invalid');
    }
  } catch (e) {
    console.error(e);
    return Astro.redirect('/admin-login?error=server');
  }
}
const error = Astro.url.searchParams.get('error');
---

<Layout title="Master Admin Login">
  <div class="min-h-screen flex items-center justify-center p-6 bg-black">
    <div class="w-full max-w-md space-y-8">
        <div class="text-center">
            <h1 class="text-4xl font-bold text-red-600 tracking-tighter mb-2">MASTER <span class="text-white text-2xl font-normal">Control</span></h1>
            <p class="text-gray-400">Restricted Access Area</p>
            
            <div class="mt-6 p-4 bg-gray-800/80 border border-gray-600 rounded-lg text-left shadow-lg">
                <p class="text-sm text-gray-300 mb-2 font-medium">Demo Access Credentials:</p>
                <div class="flex flex-col space-y-1 text-sm bg-black/50 p-2 rounded">
                    <div class="flex justify-between items-center"><span class="text-gray-500">Email:</span> <span class="text-blue-400 font-mono select-all text-right">admin@example.com</span></div>
                    <div class="flex justify-between items-center"><span class="text-gray-500">Password:</span> <span class="text-blue-400 font-mono select-all text-right">admin123</span></div>
                </div>
            </div>

            {error === 'invalid' && (
                <div class="mt-4 p-3 bg-red-900/50 border border-red-500 rounded text-red-200 text-sm font-bold animate-pulse">
                    Access Denied: Invalid Credentials
                </div>
            )}
        </div>

        <form method="POST" class="mt-8 space-y-6">
            <div class="space-y-4">
                <div class="relative">
                    <input 
                        type="email" 
                        name="email" 
                        required 
                        class="block w-full bg-[#333] border border-transparent rounded-lg py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-600 focus:bg-[#444] transition"
                        placeholder="Admin Email"
                    />
                </div>
                <div class="relative">
                    <input 
                        type="password" 
                        name="password" 
                        required 
                        class="block w-full bg-[#333] border border-transparent rounded-lg py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-600 focus:bg-[#444] transition"
                        placeholder="Secure Password"
                    />
                </div>
            </div>

            <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition">
                Authenticate
                <span class="absolute right-0 inset-y-0 flex items-center pr-3">
                    <Lock size={16} className="text-red-300 group-hover:text-white transition" />
                </span>
            </button>
        </form>
    </div>
  </div>
</Layout>
